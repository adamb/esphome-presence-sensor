# Copy this file to secrets.yaml and fill in your values

wifi_ssid: "your-wifi-ssid"
wifi_password: "your-wifi-password"

# Generate a key with: python3 -c "import secrets, base64; print(base64.b64encode(secrets.token_bytes(32)).decode())"
api_key: "your-32-character-base64-api-key"

fallback_password: "fallback-hotspot-password"